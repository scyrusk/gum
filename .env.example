# Copy to .env and adjust. All inference runs locally via Ollama by default —
# no screenshots or propositions leave your machine.

# Who the GUM is modeling (your full name).
USER_NAME="username<change this>"

# Local Ollama OpenAI-compatible endpoints (these are the defaults; shown for clarity).
GUM_LM_API_BASE="http://localhost:11434/v1"
SCREEN_LM_API_BASE="http://localhost:11434/v1"
GUM_LM_API_KEY="ollama"

# Models (pull with `ollama pull <name>`).
# Text model does proposition reasoning (reliable structured JSON output).
MODEL_NAME="qwen2.5-coder:32b"
# Vision model transcribes screenshots.
SCREEN_MODEL_NAME="qwen2.5vl:7b"

# Context-window caps (tokens). On first `gum start`, the GUM auto-creates lean
# derived models (gum-<model>-ctx<N>) with these context sizes baked in. This is
# important: Ollama otherwise loads models at their full 128K context, whose KV
# cache balloons a 7B vision model to ~50GB and forces the vision and text models
# to constantly evict each other (slow + very hot). Capping keeps both resident.
GUM_VISION_NUM_CTX="16384"
GUM_TEXT_NUM_CTX="32768"

# Local REST API (127.0.0.1 only).
GUM_API_HOST="127.0.0.1"
GUM_API_PORT="8422"

# Port for the `gum review` proposition-review GUI (127.0.0.1 only).
GUM_REVIEW_PORT="8423"

# Proposition-review feedback → few-shot calibration of the propose prompt.
# Examples per batch (0 disables), and size of the recent candidate pool the
# relevant + rating-balanced subset is chosen from.
GUM_FEWSHOT_LIMIT="8"
GUM_FEWSHOT_POOL="200"

# Optional proposition-content blacklist. The file contains one natural-language
# rule per line; blank lines and lines beginning with # are ignored. It is
# reloaded before each text-model write, so edits do not require a restart.
# Defaults to ~/.cache/gum/blacklist.txt when this setting is omitted.
# GUM_BLACKLIST_FILE="~/.cache/gum/blacklist.txt"

# Screenshots of history kept per summary call (lower = faster local inference).
HISTORY_K="2"

# Observation batching → text model. Observations are buffered in a durable,
# ack'd SQLite queue so processing progress survives `gum stop`/restarts. Idle
# flush: process a partial batch once its oldest observation has waited this many
# seconds (0 disables, leaving partial batches until enough new activity fills
# them). A batch that keeps failing to process is retried up to
# GUM_MAX_BATCH_ATTEMPTS times, then set aside as 'failed' (retained for
# inspection, not re-delivered) so a poison batch can't hot-loop and starve
# newer observations.
GUM_BATCH_TIMEOUT="30"
GUM_MAX_BATCH_ATTEMPTS="3"
# Batch size: each batch is a couple of fixed text-model calls regardless of
# size, so larger batches clear more observations per call (better drain rate at
# the same quality). Defaults MIN 5 / MAX 15.
MIN_BATCH_SIZE="5"
MAX_BATCH_SIZE="15"

# Cap observation arrival at the source: the screen observer emits at most one
# observation per this many seconds (interactions inside the window are coalesced
# away; the next emit still captures the current screen). 0 (default) disables.
# On a local GPU where the text model can't keep up during heavy use, this keeps
# the batch queue from growing unbounded — e.g. 45 targets ~1 observation/min.
GUM_MIN_OBSERVATION_INTERVAL="0"

# Keep-warm: the vision model is always kept resident for fast per-interaction
# response. The (large) text model is only used on batches, so it is released
# from memory after this many seconds with no new observations, then reloaded on
# the next batch — trading a one-time reload for a cooler, lighter idle. Set to 0
# to keep the text model always resident (hotter idle, no reload latency).
GUM_TEXT_IDLE_UNLOAD="600"

# Safety valve: set to 1 ONLY if you intentionally want to use a non-local
# inference endpoint (e.g. a GPU box on your LAN). Off by default so nothing
# can leave the machine by accident.
# GUM_ALLOW_REMOTE=0

# ── Sanitization (egress PII scrubbing for off-device / frontier consumers) ────
# Requires the extra: pip install 'gum-ai[sanitize]'. When enabled, PII is
# replaced with consistent pseudo-IDs (e.g. [PERSON_1]) so the same real entity
# reads the same across observations/propositions without exposing its identity.
# Default fallback for `gum start --sanitize` (fail-closed REST API) and for the
# CLI -s/--sanitize flag. Set to 1/true to sanitize by default.
# GUM_SANITIZE=0
# Local token-classification model that detects PII spans (runs via transformers).
GUM_SANITIZE_MODEL="openai/privacy-filter"
# Drop detected spans below this confidence (0–1). Raise to reduce false positives.
GUM_SANITIZE_MIN_SCORE="0.5"
# Where the entity ↔ pseudo-ID map (the re-identification key) is stored. Kept in
# its own file, isolated from gum.db, so it can be locked down / excluded from exports.
GUM_SANITIZE_DB="~/.cache/gum/entities.db"
# Calendar dates are PRESERVED, not pseudonymized, by default — the deadline radar
# (`gum agenda`) needs the real YYYY-MM-DD to know what's due when. A bare date is
# not a re-identifier on its own. Set to 1 to pseudonymize detected dates too.
# GUM_SANITIZE_REDACT_DATES=0


# HuggingFace token to check cache against the openai/privacy-filter model
HF_TOKEN="hf_"
