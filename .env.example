# Copy to .env and adjust. All inference runs locally via Ollama by default —
# no screenshots or propositions leave your machine.

# Who the GUM is modeling (your full name).
USER_NAME="sauvik"

# Local Ollama OpenAI-compatible endpoints (these are the defaults; shown for clarity).
GUM_LM_API_BASE="http://localhost:11434/v1"
SCREEN_LM_API_BASE="http://localhost:11434/v1"
GUM_LM_API_KEY="ollama"

# Models (pull with `ollama pull <name>`).
# Text model does proposition reasoning (reliable structured JSON output).
MODEL_NAME="qwen2.5-coder:32b"
# Vision model transcribes screenshots.
SCREEN_MODEL_NAME="qwen2.5vl:7b"

# Context-window caps (tokens). On first `gum start`, the GUM auto-creates lean
# derived models (gum-<model>-ctx<N>) with these context sizes baked in. This is
# important: Ollama otherwise loads models at their full 128K context, whose KV
# cache balloons a 7B vision model to ~50GB and forces the vision and text models
# to constantly evict each other (slow + very hot). Capping keeps both resident.
GUM_VISION_NUM_CTX="16384"
GUM_TEXT_NUM_CTX="32768"

# Local REST API (127.0.0.1 only).
GUM_API_HOST="127.0.0.1"
GUM_API_PORT="8422"

# Screenshots of history kept per summary call (lower = faster local inference).
HISTORY_K="2"

# Safety valve: set to 1 ONLY if you intentionally want to use a non-local
# inference endpoint (e.g. a GPU box on your LAN). Off by default so nothing
# can leave the machine by accident.
# GUM_ALLOW_REMOTE=0
